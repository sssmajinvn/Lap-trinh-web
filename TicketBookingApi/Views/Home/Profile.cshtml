@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

@await Html.PartialAsync("_AccountBanner")

<div class="container account-page">
    <div class="account-layout">
        <!-- Nội dung chính -->
        <div class="account-main">
            <div class="tab-container account-tabs">
                <div class="tab-header">
                    <button class="tab-btn active" id="tab-info-btn" onclick="switchAccountTab('info')">
                        <i class="fa-solid fa-id-card"></i> Thông tin tài khoản
                    </button>
                    <button class="tab-btn" id="tab-history-btn" onclick="switchAccountTab('history')">
                        <i class="fa-solid fa-ticket"></i> Lịch sử đặt vé
                    </button>
                </div>

                <!-- Tab thông tin -->
                <div id="tab-info" class="tab-pane active account-panel">
                    <h3 class="account-panel-title"><i class="fa-solid fa-user-pen text-primary"></i> Chi tiết hồ sơ</h3>
                    <form id="profile-form">
                        <div class="form-grid-2">
                            <div class="form-group">
                                <label class="form-label">Họ và tên</label>
                                <input type="text" id="input-fullname" class="form-input" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Số điện thoại</label>
                                <input type="text" id="input-phone" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Email</label>
                                <input type="email" id="input-email" class="form-input" readonly>
                                <small style="color:var(--text-muted);font-size:0.8rem;">Email không thể thay đổi (trừ tài khoản thường qua API).</small>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Ngày sinh</label>
                                <input type="date" id="input-dob" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Giới tính</label>
                                <select id="input-gender" class="form-select">
                                    <option value="1">Nam</option>
                                    <option value="0">Nữ</option>
                                    <option value="2">Khác</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Hạng thành viên</label>
                                <input type="text" id="input-rank" class="form-input" readonly>
                            </div>
                        </div>
                        <div style="margin-top: var(--space-lg); display:flex; gap:12px; flex-wrap:wrap;">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                            </button>
                            <a href="/Home/ChangePassword" class="btn btn-secondary">
                                <i class="fa-solid fa-key"></i> Đổi mật khẩu
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Tab lịch sử -->
                <div id="tab-history" class="tab-pane account-panel">
                    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:var(--space-lg);">
                        <h3 class="account-panel-title" style="margin:0;"><i class="fa-solid fa-ticket text-accent"></i> Vé đã đặt</h3>
                        <select class="form-select" style="max-width:180px;" onchange="loadBookingHistory(this.value)">
                            <option value="">Tất cả</option>
                            <option value="paid">Đã thanh toán</option>
                            <option value="pending">Chờ thanh toán</option>
                            <option value="cancelled">Đã hủy</option>
                        </select>
                    </div>
                    <div id="history-container">
                        <div style="text-align:center;padding:3rem;color:var(--text-muted);">
                            <i class="fa-solid fa-spinner fa-spin fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar thống kê -->
        <aside class="account-sidebar">
            <div class="account-stat-card">
                <div class="account-stat-icon"><i class="fa-solid fa-crown"></i></div>
                <div>
                    <span class="account-stat-label">Hạng thành viên</span>
                    <span id="sidebar-rank" class="account-stat-value">—</span>
                </div>
            </div>
            <div class="account-stat-card">
                <div class="account-stat-icon"><i class="fa-solid fa-wallet"></i></div>
                <div>
                    <span class="account-stat-label">Tổng chi tiêu</span>
                    <span id="sidebar-spent" class="account-stat-value">0₫</span>
                </div>
            </div>
            <div class="account-stat-card">
                <div class="account-stat-icon"><i class="fa-solid fa-calendar-check"></i></div>
                <div>
                    <span class="account-stat-label">Ngày tham gia</span>
                    <span id="sidebar-joined" class="account-stat-value">—</span>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        const token = localStorage.getItem('jwt_token');
        if (!token) window.location.href = '/';

        document.addEventListener('DOMContentLoaded', function() {
            loadUserProfile();
            const params = new URLSearchParams(window.location.search);
            if (params.get('tab') === 'history') {
                switchAccountTab('history');
            }
        });

        function switchAccountTab(tab) {
            document.querySelectorAll('.account-tabs .tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.account-tabs .tab-pane').forEach(p => p.classList.remove('active'));
            if (tab === 'history') {
                document.getElementById('tab-history-btn').classList.add('active');
                document.getElementById('tab-history').classList.add('active');
                loadBookingHistory();
            } else {
                document.getElementById('tab-info-btn').classList.add('active');
                document.getElementById('tab-info').classList.add('active');
            }
        }

        async function loadUserProfile() {
            try {
                const res = await fetch('/api/users/profile', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const result = await res.json();
                if (!res.ok || result.status !== 'success') return;

                const u = result.data;
                document.getElementById('input-fullname').value = u.hoten || '';
                document.getElementById('input-email').value = u.email || '';
                document.getElementById('input-phone').value = u.sdt || '';
                document.getElementById('input-dob').value = u.ngaysinh ? u.ngaysinh.split('T')[0] : '';
                document.getElementById('input-gender').value = u.gioitinh !== undefined && u.gioitinh !== null ? u.gioitinh : 1;
                document.getElementById('input-rank').value = u.hangThanhVien || 'Mới';

                document.getElementById('sidebar-rank').textContent = u.hangThanhVien || 'Mới';
                document.getElementById('sidebar-spent').textContent = new Intl.NumberFormat('vi-VN').format(u.tongChiTieu || 0) + '₫';
                document.getElementById('sidebar-joined').textContent = u.ngaytao
                    ? new Date(u.ngaytao).toLocaleDateString('vi-VN') : '—';
            } catch (e) { console.error(e); }
        }

        document.getElementById('profile-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = {
                hoTen: document.getElementById('input-fullname').value,
                sdt: document.getElementById('input-phone').value,
                ngaySinh: document.getElementById('input-dob').value || null,
                gioiTinh: parseInt(document.getElementById('input-gender').value)
            };

            try {
                const res = await fetch('/api/users/profile', {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                const r = await res.json();
                if (res.ok) {
                    alert('Cập nhật thông tin thành công!');
                    loadUserProfile();
                    const userData = JSON.parse(localStorage.getItem('user_data') || '{}');
                    userData.hoTen = data.hoTen;
                    localStorage.setItem('user_data', JSON.stringify(userData));
                } else {
                    alert(r.message || 'Có lỗi xảy ra');
                }
            } catch { alert('Lỗi kết nối máy chủ'); }
        });

        async function loadBookingHistory(status = '') {
            const container = document.getElementById('history-container');
            container.innerHTML = '<div style="text-align:center;padding:3rem;"><i class="fa-solid fa-spinner fa-spin fa-2x"></i></div>';

            try {
                const url = `/api/users/booking-history?limit=20${status ? '&status=' + status : ''}`;
                const res = await fetch(url, { headers: { 'Authorization': `Bearer ${token}` } });
                const result = await res.json();

                if (!res.ok || result.status !== 'success') {
                    container.innerHTML = '<p style="text-align:center;color:#ff4757;">Lỗi tải lịch sử.</p>';
                    return;
                }

                const history = result.data;
                if (!history.length) {
                    container.innerHTML = '<div style="text-align:center;padding:3rem;color:var(--text-muted);"><i class="fa-solid fa-ticket fa-2x" style="opacity:0.4;margin-bottom:12px;"></i><p>Bạn chưa có giao dịch nào.</p></div>';
                    return;
                }

                container.innerHTML = history.map(item => {
                    const statusLabel = item.trangThai === 'paid' ? 'Đã thanh toán'
                        : (item.trangThai === 'pending' ? 'Chờ thanh toán' : 'Đã hủy');
                    const statusCls = item.trangThai === 'paid' ? 'showing'
                        : (item.trangThai === 'pending' ? 'pending' : 'hidden');
                    return `
                    <div class="history-card">
                        <img src="${item.posterUrl || 'https://images.unsplash.com/photo-1536440136628-849c177e76a1?w=200'}" class="history-poster" alt="">
                        <div class="history-card-body">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;flex-wrap:wrap;">
                                <h4 style="margin:0;font-size:1.05rem;">${item.tenPhim || 'Phim'}</h4>
                                <span class="badge-status ${statusCls}">${statusLabel}</span>
                            </div>
                            <p style="font-size:0.85rem;color:var(--text-muted);margin:6px 0;"><i class="fa-solid fa-location-dot"></i> ${item.tenRapPhim || ''} · ${item.tenPhong || ''}</p>
                            <p style="font-size:0.85rem;color:var(--text-muted);margin:0;"><i class="fa-solid fa-calendar"></i> ${item.ngayChieu || ''} · ${item.gioChieu || ''}</p>
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;flex-wrap:wrap;gap:8px;">
                                <span style="font-weight:700;color:var(--color-accent);">${new Intl.NumberFormat('vi-VN').format(item.tongTien)}₫ <small style="color:var(--text-muted);font-weight:400;">(${item.tickets.length} vé)</small></span>
                                ${item.trangThai === 'paid' ? `<a href="/Home/Success?orderId=${item.maDonDatVe}" class="btn btn-secondary" style="padding:6px 14px;font-size:0.8rem;">Xem QR</a>` : ''}
                                ${item.trangThai === 'pending' ? `<button class="btn btn-outline" style="padding:6px 14px;font-size:0.8rem;" onclick="cancelOrder('${item.maDonDatVe}')">Hủy đơn</button>` : ''}
                            </div>
                        </div>
                    </div>`;
                }).join('');
            } catch {
                container.innerHTML = '<p style="text-align:center;color:#ff4757;">Lỗi kết nối.</p>';
            }
        }

        async function cancelOrder(id) {
            if (!confirm('Bạn có chắc muốn hủy đơn hàng này?')) return;
            const res = await fetch(`/api/bookings/${id}/cancel`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                alert('Đã hủy đơn hàng.');
                loadBookingHistory();
                loadUserProfile();
            } else {
                alert('Không thể hủy đơn.');
            }
        }
    </script>
}
