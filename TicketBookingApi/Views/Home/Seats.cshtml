@{
    var showtimeId = ViewData["ShowtimeId"] as string;
    ViewData["Title"] = "Chọn ghế ngồi";
}

<div class="container" style="min-height: 85vh;">
    <div class="seat-selection-wrapper">
        
        <!-- 🗺️ SEAT MAP AREA -->
        <div class="seat-map-section">
            <div class="screen-container">
                <div class="screen-visual"></div>
                <div class="screen-text">MÀN HÌNH</div>
            </div>

            <!-- Seat Grid (Populated by JS) -->
            <div id="seat-grid-container" class="seat-grid">
                <div style="padding: 3rem; text-align: center; color: var(--text-muted);">
                    <i class="fa-solid fa-spinner fa-spin fa-3x" style="margin-bottom: 1rem;"></i>
                    <p>Đang bố trí sơ đồ ghế ngồi...</p>
                </div>
            </div>

            <!-- Legend -->
            <div class="seat-legend">
                <div class="legend-item">
                    <div class="legend-seat" style="background-color: #3e4b5e;"></div>
                    <span>Thường</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat" style="background-color: #f1c40f;"></div>
                    <span>VIP</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat" style="background-color: var(--color-primary);"></div>
                    <span>Đang chọn</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat" style="background-color: #ff9f43; opacity: 0.6;"></div>
                    <span>Đang giữ</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat" style="background-color: #1a2332; position: relative; border: 1px solid var(--glass-border);">
                        <i class="fa-solid fa-times" style="font-size: 10px; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); color: var(--text-muted);"></i>
                    </div>
                    <span>Đã bán</span>
                </div>
            </div>

            <!-- 🍿 CONCESSIONS AREA -->
            <div class="concessions-section">
                <h3 class="section-title">Chọn Bắp nước & Combo</h3>
                <div id="concessions-container" class="concessions-grid">
                    <!-- Populated by JS -->
                </div>
            </div>
        </div>

        <!-- 📝 SUMMARY SIDEBAR -->
        <div class="booking-summary-sidebar">
            <div class="summary-movie-info">
                <h2 id="summary-movie-title" class="summary-title">Đang tải...</h2>
                <div id="summary-showtime-info" class="summary-meta">
                    <i class="fa-solid fa-location-dot"></i> <span id="summary-theater-name">...</span><br>
                    <i class="fa-regular fa-calendar"></i> <span id="summary-date">...</span> - <i class="fa-regular fa-clock"></i> <span id="summary-time">...</span>
                </div>
            </div>

            <div class="summary-selection-row">
                <span>Ghế đã chọn:</span>
                <span id="seat-count-text" style="font-weight: 700; color: var(--color-primary);">0 ghế</span>
            </div>
            
            <div id="selected-seats-list" class="selected-seats-badges">
                <!-- Badges like A1, A2 will appear here -->
                <span style="color: var(--text-muted); font-style: italic; font-size: 0.85rem;">Chưa có ghế nào được chọn</span>
            </div>

            <div id="selected-concessions-summary" style="margin-top: 12px; font-size: 0.85rem; color: var(--text-muted);">
                <!-- Selected combos will appear here -->
            </div>

            <!-- 🎫 VOUCHER SECTION -->
            <div class="voucher-box">
                <div class="summary-selection-row">
                    <span>Mã giảm giá:</span>
                    <span id="voucher-discount-text" style="color: #2ed573; font-weight: 700;">-0₫</span>
                </div>
                <div class="voucher-input-wrapper">
                    <input type="text" id="voucher-code-input" class="voucher-input" placeholder="Nhập mã ưu đãi...">
                    <button class="btn btn-secondary btn-apply-voucher" onclick="applyVoucher()">ÁP DỤNG</button>
                </div>
                <div id="voucher-msg" style="font-size: 0.75rem; margin-top: 4px;"></div>
            </div>

            <div class="summary-total">
                <div style="font-size: 0.9rem; color: var(--text-muted);">Tạm tính:</div>
                <div id="total-amount" class="total-price">0₫</div>
            </div>

            <button id="btn-proceed-booking" class="btn btn-primary btn-block" style="margin-top: var(--space-lg); height: 54px; font-size: 1.1rem;" disabled onclick="proceedToBooking()">
                TIẾP TỤC <i class="fa-solid fa-arrow-right"></i>
            </button>
            
            <p style="margin-top: 1rem; font-size: 0.8rem; color: var(--text-muted); text-align: center;">
                <i class="fa-solid fa-circle-info"></i> Bạn có thể chọn tối đa 6 ghế cùng lúc.
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const showtimeId = "@showtimeId";
        let selectedSeats = []; // Array of seat objects {id, code, price}
        let selectedConcessions = []; // Array of {id, type, price, quantity, name}
        let appliedVoucher = null; // {code, discountAmount}
        let seatData = []; // Full list from API
        let hubConnection = null;

        document.addEventListener('DOMContentLoaded', function() {
            loadSeats();
            loadConcessions();
            setupSignalR();
        });

        // 1. Tải danh sách ghế từ API
        async function loadSeats() {
            try {
                const response = await fetch(`/api/bookings/showtimes/${showtimeId}/seats`);
                const result = await response.json();
                
                if (response.ok && result.status === 'success') {
                    const data = result.data;
                    seatData = data.ghe;
                    
                    // Cập nhật thông tin tóm tắt
                    document.getElementById('summary-movie-title').textContent = data.tenphim || "Đang tải...";
                    document.getElementById('summary-theater-name').textContent = data.rap || "Rạp Ticket Cinema";
                    document.getElementById('summary-date').textContent = data.ngaychieu;
                    document.getElementById('summary-time').textContent = data.giochieu + " - " + (data.phong || "Phòng chiếu");
                    
                    renderSeatGrid(seatData);
                }
            } catch (err) {
                console.error("Lỗi load ghế:", err);
            }
        }

        // 2. Hiển thị lưới ghế
        function renderSeatGrid(seats) {
            const container = document.getElementById('seat-grid-container');
            container.innerHTML = '';
            
            const rows = {};
            seats.forEach(s => {
                if (!rows[s.mahangghe]) rows[s.mahangghe] = [];
                rows[s.mahangghe].push(s);
            });

            const rowKeys = Object.keys(rows).sort();
            const maxCols = Math.max(...seats.map(s => s.soghe));
            container.style.gridTemplateColumns = `repeat(${maxCols}, 34px)`;

            rowKeys.forEach(rowKey => {
                const rowSeats = rows[rowKey].sort((a, b) => a.soghe - b.soghe);
                rowSeats.forEach(s => {
                    const status = s.status; // 'booked', 'locked', 'available'
                    const isVip = s.loaighe === "vip" || s.loaighe === "VIP";
                    const seatClass = `seat ${status} ${isVip ? 'vip' : ''}`;
                    const seatCode = `${s.mahangghe}${s.soghe}`;
                    
                    const seatEl = document.createElement('div');
                    seatEl.className = seatClass;
                    seatEl.id = `seat-${s.maghe}`;
                    seatEl.dataset.id = s.maghe;
                    seatEl.dataset.code = seatCode;
                    seatEl.dataset.price = s.giaVe;
                    seatEl.textContent = seatCode;
                    
                    if (status === 'available') {
                        seatEl.onclick = () => toggleSeatSelection(s.maghe, seatCode, s.giaVe);
                    } else {
                        seatEl.style.pointerEvents = 'none';
                    }
                    
                    container.appendChild(seatEl);
                });
            });
        }

        // 3. Xử lý chọn/bỏ chọn ghế
        function toggleSeatSelection(id, code, price) {
            const seatEl = document.getElementById(`seat-${id}`);
            const index = selectedSeats.findIndex(s => s.id === id);

            if (index > -1) {
                // Bỏ chọn
                selectedSeats.splice(index, 1);
                seatEl.classList.remove('selected');
                // SignalR: Unlock seat
                if (hubConnection) hubConnection.invoke("UnlockSeat", showtimeId, id);
            } else {
                // Chọn mới (tối đa 6)
                if (selectedSeats.length >= 6) {
                    alert("Bạn chỉ được phép chọn tối đa 6 ghế!");
                    return;
                }
                selectedSeats.push({ id, code, price });
                seatEl.classList.add('selected');
                // SignalR: Lock seat
                if (hubConnection) hubConnection.invoke("LockSeat", showtimeId, id);
            }

            updateSummary();
        }

        // 3.5 Tải danh sách Bắp nước
        async function loadConcessions() {
            try {
                const [itemsRes, combosRes] = await Promise.all([
                    fetch('/api/concessions/items'),
                    fetch('/api/concessions/combos')
                ]);
                
                const itemsData = await itemsRes.json();
                const combosData = await combosRes.json();
                
                const container = document.getElementById('concessions-container');
                container.innerHTML = '';

                // Render Combos first
                if (combosData.status === 'success') {
                    combosData.data.forEach(c => renderConcessionCard(c, 'combo', container));
                }
                // Render Items
                if (itemsData.status === 'success') {
                    itemsData.data.forEach(i => renderConcessionCard(i, 'item', container));
                }
            } catch (err) {
                console.error("Lỗi load bắp nước:", err);
            }
        }

        function renderConcessionCard(item, type, container) {
            const id = type === 'combo' ? item.comboId : item.itemId;
            const card = document.createElement('div');
            card.className = 'concession-card';
            card.innerHTML = `
                <img src="${item.imageUrl || '/img/default-food.png'}" class="concession-img" alt="${item.name}">
                <div class="concession-info">
                    <div class="concession-name">${item.name}</div>
                    <div class="concession-price">${new Intl.NumberFormat('vi-VN').format(item.price)}₫</div>
                </div>
                <div class="quantity-control">
                    <button class="qty-btn" onclick="updateConcessionQty(${id}, '${type}', -1, '${item.name}', ${item.price})">-</button>
                    <span class="qty-val" id="qty-${type}-${id}">0</span>
                    <button class="qty-btn" onclick="updateConcessionQty(${id}, '${type}', 1, '${item.name}', ${item.price})">+</button>
                </div>
            `;
            container.appendChild(card);
        }

        function updateConcessionQty(id, type, delta, name, price) {
            const index = selectedConcessions.findIndex(c => c.id === id && c.type === type);
            
            if (index > -1) {
                selectedConcessions[index].quantity += delta;
                if (selectedConcessions[index].quantity <= 0) {
                    selectedConcessions.splice(index, 1);
                }
            } else if (delta > 0) {
                selectedConcessions.push({ id, type, name, price, quantity: 1 });
            }

            const qty = selectedConcessions.find(c => c.id === id && c.type === type)?.quantity || 0;
            document.getElementById(`qty-${type}-${id}`).textContent = qty;
            
            updateSummary();
        }

        // 3.6 Áp dụng Voucher
        async function applyVoucher() {
            const code = document.getElementById('voucher-code-input').value.trim();
            const msgEl = document.getElementById('voucher-msg');
            const token = localStorage.getItem('jwt_token');

            if (!code) {
                appliedVoucher = null;
                updateSummary();
                return;
            }

            try {
                const response = await fetch(`/api/vouchers/check?code=${code}&totalAmount=${calculateSubtotal()}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const result = await response.json();

                if (response.ok && result.status === 'success') {
                    appliedVoucher = {
                        code: code,
                        discountAmount: result.data.discountAmount
                    };
                    msgEl.style.color = '#2ed573';
                    msgEl.textContent = `Áp dụng thành công: Giảm ${new Intl.NumberFormat('vi-VN').format(result.data.discountAmount)}₫`;
                } else {
                    appliedVoucher = null;
                    msgEl.style.color = '#ff4757';
                    msgEl.textContent = result.message || "Mã không hợp lệ hoặc không đủ điều kiện.";
                }
                updateSummary();
            } catch (err) {
                console.error(err);
            }
        }

        function calculateSubtotal() {
            const seatsTotal = selectedSeats.reduce((sum, s) => sum + s.price, 0);
            const concessionsTotal = selectedConcessions.reduce((sum, c) => sum + (c.price * c.quantity), 0);
            return seatsTotal + concessionsTotal;
        }

        // 4. Cập nhật Sidebar
        function updateSummary() {
            const countEl = document.getElementById('seat-count-text');
            const listEl = document.getElementById('selected-seats-list');
            const concEl = document.getElementById('selected-concessions-summary');
            const discountEl = document.getElementById('voucher-discount-text');
            const totalEl = document.getElementById('total-amount');
            const btn = document.getElementById('btn-proceed-booking');

            countEl.textContent = `${selectedSeats.length} ghế`;
            
            if (selectedSeats.length === 0) {
                listEl.innerHTML = '<span style="color: var(--text-muted); font-style: italic; font-size: 0.85rem;">Chưa có ghế nào được chọn</span>';
                concEl.innerHTML = '';
                totalEl.textContent = '0₫';
                discountEl.textContent = '-0₫';
                btn.disabled = true;
                return;
            }

            listEl.innerHTML = selectedSeats.map(s => `<span class="badge-seat">${s.code}</span>`).join('');
            
            // Concessions summary
            concEl.innerHTML = selectedConcessions.map(c => `<div>${c.name} x${c.quantity}</div>`).join('');

            const subtotal = calculateSubtotal();
            const discount = appliedVoucher ? appliedVoucher.discountAmount : 0;
            const finalTotal = Math.max(0, subtotal - discount);

            discountEl.textContent = `-${new Intl.NumberFormat('vi-VN').format(discount)}₫`;
            totalEl.textContent = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(finalTotal);
            btn.disabled = false;
        }

        // 5. SignalR Setup
        async function setupSignalR() {
            const token = localStorage.getItem('jwt_token');
            if (!token) return;

            hubConnection = new signalR.HubConnectionBuilder()
                .withUrl(`/seathub?access_token=${token}`)
                .withAutomaticReconnect()
                .build();

            hubConnection.on("ReceiveSeatStatus", (data) => {
                // data: { seatIds: [], status: "locked" | "available" | "pending" }
                data.seatIds.forEach(sid => {
                    const el = document.getElementById(`seat-${sid}`);
                    if (!el) return;
                    
                    // Nếu là ghế MÌNH đang chọn thì không thay đổi gì cả (để giữ trạng thái .selected)
                    if (selectedSeats.find(s => s.id === sid)) return;

                    if (data.status === "locked" || data.status === "pending") {
                        // "pending" trong Hub nghĩa là có ai đó vừa Lock ghế tạm thời
                        el.classList.add('locked');
                        el.classList.remove('available');
                        el.style.pointerEvents = 'none';
                    } else if (data.status === "available") {
                        el.classList.remove('locked');
                        el.classList.remove('booked');
                        el.classList.add('available');
                        el.style.pointerEvents = 'auto';
                    } else if (data.status === "active") {
                        // "active" thường là đã thanh toán thành công
                        el.classList.add('booked');
                        el.classList.remove('available');
                        el.classList.remove('locked');
                        el.style.pointerEvents = 'none';
                    }
                });
            });

            try {
                await hubConnection.start();
                console.log("SignalR Connected!");
                // Join group for this showtime
                hubConnection.invoke("JoinShowtime", showtimeId);
            } catch (err) {
                console.error("SignalR Error:", err);
            }
        }

        // 6. Proceed to Booking (API Call)
        async function proceedToBooking() {
            const token = localStorage.getItem('jwt_token');
            if (!token) {
                alert("Vui lòng đăng nhập để tiếp tục!");
                return;
            }

            const seatIds = selectedSeats.map(s => s.id);
            
            try {
                const response = await fetch('/api/bookings/book', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        showtimeId: showtimeId,
                        seatIds: seatIds,
                        paymentMethod: 'vnpay',
                        maVoucher: appliedVoucher ? appliedVoucher.code : null,
                        concessions: selectedConcessions.map(c => ({
                            id: c.id,
                            type: c.type,
                            quantity: c.quantity
                        }))
                    })
                });

                const result = await response.json();
                if ((response.status === 201 || response.status === 200) && result.status === 'success') {
                    // Chuyển hướng sang trang chờ thanh toán hoặc trang thành công
                    alert("Đặt chỗ thành công! Đang chuyển đến trang thanh toán...");
                    
                    // Nếu là VNPAY/PayOS và có URL trả về (giả sử backend có trả về paymentUrl)
                    if (result.data.paymentUrl) {
                        window.location.href = result.data.paymentUrl;
                    } else {
                        // Fallback về trang chờ
                        window.location.href = `/PaymentWaiting.html?orderId=${result.data.maDonDatVe}`;
                    }
                } else {
                    alert(result.message || "Đã có lỗi xảy ra khi giữ ghế. Ghế có thể đã được người khác đặt.");
                    window.location.reload();
                }
            } catch (err) {
                console.error(err);
                alert("Lỗi kết nối máy chủ.");
            }
        }
    </script>
}
