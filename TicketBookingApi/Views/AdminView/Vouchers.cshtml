@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Voucher & Khuyến Mãi";
}

<div class="module-header">
    <div class="header-left">
        <h3><i class="fa-solid fa-ticket-simple text-danger"></i> Danh sách Mã Khuyến Mãi</h3>
        <p class="text-muted">Quản lý các chương trình ưu đãi và mã giảm giá cho khách hàng.</p>
    </div>
    <button class="btn btn-primary" onclick="showCreateVoucherModal()">
        <i class="fa-solid fa-plus"></i> Tạo Voucher Mới
    </button>
</div>

<div class="data-card mt-4">
    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Mã Voucher</th>
                    <th>Tên Chương Trình</th>
                    <th>Loại Giảm</th>
                    <th>Giá Trị</th>
                    <th>Sử Dụng</th>
                    <th>Thời Hạn</th>
                    <th>Trạng Thái</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody id="voucher-list-tbody">
                <tr>
                    <td colspan="8" style="text-align: center; padding: 3rem;">
                        <i class="fa-solid fa-spinner fa-spin fa-2x mb-3"></i>
                        <p>Đang tải danh sách voucher...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            loadVouchers();
        });

        async function loadVouchers() {
            const tbody = document.getElementById('voucher-list-tbody');
            const token = localStorage.getItem('admin_token');

            try {
                const response = await fetch('/api/admin/vouchers', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!response.ok) {
                    if (response.status === 401) throw new Error("Phiên đăng nhập hết hạn.");
                    throw new Error(`Lỗi (${response.status})`);
                }

                const result = await response.json();

                if (response.ok && result.status === 'success') {
                    const vouchers = result.data;
                    tbody.innerHTML = '';

                    if (vouchers.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="8" style="text-align: center;">Chưa có mã giảm giá nào</td></tr>';
                        return;
                    }

                    vouchers.forEach(v => {
                        const statusClass = v.trangThai === 'ACTIVE' ? 'status-active' : 'status-inactive';
                        const discountDisplay = v.loaiGiam === 'PHAN_TRAM' 
                            ? `<span class="badge badge-pg16">${v.giaTriGiam}%</span>`
                            : `<span class="text-success" style="font-weight:700">${new Intl.NumberFormat('vi-VN').format(v.giaTriGiam)}₫</span>`;

                        tbody.innerHTML += `
                            <tr>
                                <td><code style="font-size: 1rem; color: #ff2e3b; font-weight: 700;">${v.maKhuyenMai}</code></td>
                                <td><div style="font-weight:600">${v.tenKhuyenMai}</div></td>
                                <td>${v.loaiGiam === 'PHAN_TRAM' ? 'Giảm %' : 'Giảm tiền mặt'}</td>
                                <td>${discountDisplay}</td>
                                <td>
                                    <div style="font-size: 0.85rem;">${v.soLuongDaDung} / ${v.soLuongMa}</div>
                                    <div class="progress-mini" style="width: 100px; height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 4px;">
                                        <div style="width: ${(v.soLuongDaDung/v.soLuongMa)*100}%; height: 100%; background: var(--color-primary); border-radius: 2px;"></div>
                                    </div>
                                </td>
                                <td style="font-size: 0.8rem; color: var(--text-muted);">
                                    ${new Date(v.ngayBatDau).toLocaleDateString('vi-VN')} -<br>
                                    ${new Date(v.ngayKetThuc).toLocaleDateString('vi-VN')}
                                </td>
                                <td><span class="status-pills ${statusClass}">${v.trangThai}</span></td>
                                <td>
                                    <div style="display:flex; gap: 8px;">
                                        <button class="btn btn-secondary btn-sm" onclick="showVoucherModal('${v.id}')" title="Sửa">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button class="btn btn-outline btn-sm text-danger" onclick="deleteVoucher('${v.id}')" title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        `;
                    });
                }
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; color: var(--color-primary);">Lỗi kết nối API: ${err.message}</td></tr>`;
            }
        }

        let editingVoucherId = null;

        async function showVoucherModal(id = null) {
            editingVoucherId = id;
            const modal = document.getElementById('voucher-modal');
            const title = document.getElementById('modal-voucher-title');
            const form = document.getElementById('voucher-form');
            
            form.reset();
            document.getElementById('maKhuyenMai').disabled = false;
            
            if (id) {
                title.innerHTML = '<i class="fa-solid fa-pen-to-square"></i> Cập Nhật Voucher';
                const token = localStorage.getItem('admin_token');
                const res = await fetch(`/api/admin/vouchers/${id}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const result = await res.json();
                if (res.ok) {
                    const v = result.data;
                    document.getElementById('maKhuyenMai').value = v.maKhuyenMai;
                    document.getElementById('maKhuyenMai').disabled = true;
                    document.getElementById('tenKhuyenMai').value = v.tenKhuyenMai;
                    document.getElementById('loaiGiam').value = v.loaiGiam;
                    document.getElementById('giaTriGiam').value = v.giaTriGiam;
                    document.getElementById('soLuongMa').value = v.soLuongMa;
                    document.getElementById('ngayBatDau').value = v.ngayBatDau.split('T')[0];
                    document.getElementById('ngayKetThuc').value = v.ngayKetThuc.split('T')[0];
                    document.getElementById('trangThai').value = v.trangThai;
                }
            } else {
                title.innerHTML = '<i class="fa-solid fa-plus"></i> Tạo Voucher Mới';
                document.getElementById('ngayBatDau').value = new Date().toISOString().split('T')[0];
            }
            
            modal.style.display = 'flex';
        }

        function closeVoucherModal() {
            document.getElementById('voucher-modal').style.display = 'none';
        }

        async function handleVoucherSubmit(event) {
            event.preventDefault();
            const token = localStorage.getItem('admin_token');
            const formData = {
                maKhuyenMai: document.getElementById('maKhuyenMai').value,
                tenKhuyenMai: document.getElementById('tenKhuyenMai').value,
                loaiGiam: document.getElementById('loaiGiam').value,
                giaTriGiam: parseFloat(document.getElementById('giaTriGiam').value),
                soLuongMa: parseInt(document.getElementById('soLuongMa').value),
                ngayBatDau: document.getElementById('ngayBatDau').value,
                ngayKetThuc: document.getElementById('ngayKetThuc').value,
                trangThai: document.getElementById('trangThai').value,
                moTa: document.getElementById('tenKhuyenMai').value,
                apDungCho: "TAT_CA_PHIM",
                apDungUser: "TAT_CA_USER"
            };

            const url = editingVoucherId ? `/api/admin/vouchers/${editingVoucherId}` : '/api/admin/vouchers';
            const method = editingVoucherId ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
                const result = await res.json();
                if (res.ok) {
                    alert(editingVoucherId ? "Cập nhật thành công!" : "Tạo voucher thành công!");
                    closeVoucherModal();
                    loadVouchers();
                } else {
                    alert("Lỗi: " + result.message);
                }
            } catch (e) {
                alert("Lỗi kết nối server: " + e.message);
            }
        }

        function showCreateVoucherModal() {
            showVoucherModal();
        }

        async function deleteVoucher(id) {
            if (confirm("Bạn có chắc chắn muốn xóa mã voucher này?")) {
                const token = localStorage.getItem('admin_token');
                try {
                    const res = await fetch(`/api/admin/vouchers/${id}`, {
                        method: 'DELETE',
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    if (res.ok) {
                        alert("Đã xóa thành công.");
                        loadVouchers();
                    } else {
                        const result = await res.json();
                        alert("Lỗi: " + result.message);
                    }
                } catch (e) {
                    alert("Lỗi kết nối server.");
                }
            }
        }
    </script>
}

<!-- 📦 MODAL VOUCHER -->
<div id="voucher-modal" class="admin-modal-backdrop" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:9999; justify-content:center; align-items:center;">
    <div class="modal-card" style="width: 500px; background: #1a1a1e; border: 1px solid var(--glass-border); border-radius: 12px; padding: 24px;">
        <div class="modal-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h3 id="modal-voucher-title" style="margin:0; color:var(--color-primary);"></h3>
            <button onclick="closeVoucherModal()" style="background:none; border:none; color:#fff; font-size:24px; cursor:pointer;">&times;</button>
        </div>
        <form id="voucher-form" onsubmit="handleVoucherSubmit(event)">
            <div class="form-group mb-3">
                <label class="form-label">Mã Voucher</label>
                <input type="text" id="maKhuyenMai" class="form-input" placeholder="Ví dụ: KM50K" required style="text-transform:uppercase">
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Tên Chương Trình</label>
                <input type="text" id="tenKhuyenMai" class="form-input" placeholder="Tên hiển thị cho khách hàng" required>
            </div>
            <div style="display:flex; gap:15px;" class="mb-3">
                <div class="form-group" style="flex:1">
                    <label class="form-label">Loại Giảm</label>
                    <select id="loaiGiam" class="form-input">
                        <option value="PHAN_TRAM">Phần trăm (%)</option>
                        <option value="TIEN">Số tiền cố định (đ)</option>
                    </select>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label">Giá Trị Giảm</label>
                    <input type="number" id="giaTriGiam" class="form-input" required>
                </div>
            </div>
            <div style="display:flex; gap:15px;" class="mb-3">
                <div class="form-group" style="flex:1">
                    <label class="form-label">Tổng Số Lượng</label>
                    <input type="number" id="soLuongMa" class="form-input" required>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label">Trạng Thái</label>
                    <select id="trangThai" class="form-input">
                        <option value="ACTIVE">Hoạt động</option>
                        <option value="INACTIVE">Tạm ngưng</option>
                    </select>
                </div>
            </div>
            <div style="display:flex; gap:15px;" class="mb-4">
                <div class="form-group" style="flex:1">
                    <label class="form-label">Ngày Bắt Đầu</label>
                    <input type="date" id="ngayBatDau" class="form-input" required>
                </div>
                <div class="form-group" style="flex:1">
                    <label class="form-label">Ngày Kết Thúc</label>
                    <input type="date" id="ngayKetThuc" class="form-input" required>
                </div>
            </div>
            <div style="display:flex; gap:10px; justify-content:flex-end;">
                <button type="button" class="btn btn-outline" onclick="closeVoucherModal()">Hủy</button>
                <button type="submit" class="btn btn-primary">Lưu Voucher</button>
            </div>
        </form>
    </div>
</div>

<style>
    .admin-modal-backdrop { backdrop-filter: blur(8px); }
    .status-pills { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
    .status-active { background: rgba(46, 213, 115, 0.15); color: #2ed573; border: 1px solid rgba(46, 213, 115, 0.3); }
    .status-inactive { background: rgba(255, 71, 87, 0.15); color: #ff4757; border: 1px solid rgba(255, 71, 87, 0.3); }
</style>
